# Cloud sync (optional). Copy to ".env.local" and fill in to enable Google
# sign-in + progress sync. Leave unset to run fully local/offline.
#
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: on-device speech model location (see public/models/README.md).
# NEXT_PUBLIC_VOSK_MODEL_URL=/models/vosk-model-small-de.tar.gz
